@startuml
skinparam state {
  BackgroundColor White
  BorderColor Black
}

title Payment Saga State Machine

[*] --> NEW

NEW --> RISK_CHECKING : INITIATE\n/ evaluateRiskAction\n(err: evaluateRiskErrorAction)

RISK_CHECKING --> MANUAL_REVIEW : RISK_EVALUATED\n[requireReviewGuard]
RISK_CHECKING --> FUNDS_RESERVING : RISK_EVALUATED\n[riskCheckGuard]\n/ feeCalculationAction\n(err: feeCalculationErrorAction)
RISK_CHECKING --> REJECTED : RISK_EVALUATED\n[riskRejectedGuard]

MANUAL_REVIEW --> FUNDS_RESERVING : ANALYST_APPROVE\n/ feeCalculationAction\n(err: feeCalculationErrorAction)
MANUAL_REVIEW --> REJECTED : ANALYST_REJECT

FUNDS_RESERVING --> FEE_RESERVING : FUNDS_RESERVED\n/ reserveFeeAction\n(err: reserveFeeErrorAction)
FUNDS_RESERVING --> FAILED : FUNDS_RESERVATION_FAILED

FEE_RESERVING --> ACCOUNTING_POSTING : FEE_RESERVED\n/ postLedgerAction\n(err: postLedgerErrorAction)
FEE_RESERVING --> COMPENSATING : FEE_RESERVATION_FAILED\n/ unreserveBaseAmountAction\n(err: unreserveBaseAmountErrorAction)

ACCOUNTING_POSTING --> COMPLETED : ENTRIES_POSTED\n/ settlementAction\n(err: settlementErrorAction)
ACCOUNTING_POSTING --> COMPENSATING : POSTING_FAILED\n/ compensateSagaAction\n(err: compensateSagaErrorAction)

COMPENSATING --> FAILED : COMPENSATION_COMPLETE

state COMPLETED {
  COMPLETED : entry / completedEntryAction
}

COMPLETED --> REFUNDED : REFUND\n[refundWindowGuard]

@enduml
