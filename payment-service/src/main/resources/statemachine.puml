@startuml
skinparam state {
  BackgroundColor White
  BorderColor Black
}

title Payment State Machine with Orthogonal Regions

[*] --> NEW

NEW --> PROCESSING : INITIATE

state PROCESSING {
  state Authorization {
    [*] --> AUTH_PENDING

    AUTH_PENDING --> AUTH_APPROVED : AUTHORIZE\n[fraudCheckGuard]\n/ feeCalculationAction\n  (err: feeCalculationErrorAction)
    AUTH_PENDING --> AUTH_REJECTED : AUTHORIZE\n[fraudCheckGuard → HIGH risk]
  }

  --

  state FraudCheck {
    [*] --> FRAUD_EVALUATING
    FRAUD_EVALUATING --> FRAUD_PASSED  : FRAUD_CLEAR
    FRAUD_EVALUATING --> FRAUD_DETECTED : FRAUD_ALERT
  }
}

PROCESSING --> COMPLETED : COMPLETE\n/ settlementAction\n  (err: settlementErrorAction)
note on link
  **Guard:** AUTH_APPROVED
  **AND** FRAUD_PASSED
end note

PROCESSING --> FAILED : FAIL
note on link
  AUTH_REJECTED
  **OR** FRAUD_DETECTED
end note

PROCESSING --> CANCELED : CANCEL

state COMPLETED {
  COMPLETED : entry / completedEntryAction\n  (skipped when isRestoring=true)
}

COMPLETED --> REFUNDED : REFUND\n[refundWindowGuard]\n(30-day window)

@enduml
